{
  "name": "process-designer",
  "displayName": "Process Designer",
  "description": "BPMN and Camunda Form modeling in VS Code via webview. Unofficial community extension — not affiliated with Camunda or bpmn.io.",
  "version": "0.0.2",
  "publisher": "RineSong",
  "license": "MIT",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sliver47/bpmn-modeler.git"
  },
  "bugs": {
    "url": "https://github.com/sliver47/bpmn-modeler/issues"
  },
  "homepage": "https://github.com/sliver47/bpmn-modeler#readme",
  "keywords": [
    "bpmn",
    "bpmn2",
    "camunda",
    "form",
    "workflow",
    "process",
    "modeler"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onCustomEditor:bpmn-modeler.bpmnEditor",
    "onCustomEditor:bpmn-modeler.formEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "bpmn",
        "aliases": [
          "BPMN",
          "bpmn"
        ],
        "extensions": [
          ".bpmn"
        ],
        "icon": {
          "light": "resources/icons/light/bpmn.svg",
          "dark": "resources/icons/dark/bpmn.svg"
        }
      },
      {
        "id": "camunda-form",
        "aliases": [
          "Camunda Form",
          "form"
        ],
        "extensions": [
          ".form"
        ],
        "icon": {
          "light": "resources/icons/light/form.svg",
          "dark": "resources/icons/dark/form.svg"
        }
      }
    ],
    "commands": [
      {
        "command": "bpmn-modeler.openWithModeler",
        "title": "Open with BPMN Modeler",
        "category": "BPMN Modeler"
      },
      {
        "command": "bpmn-modeler.openFormEditor",
        "title": "Open with Form Editor",
        "category": "BPMN Modeler"
      },
      {
        "command": "bpmn-modeler.deploy",
        "title": "Deploy to Camunda",
        "category": "BPMN Modeler",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "bpmn-modeler.showOutput",
        "title": "Show Output",
        "category": "BPMN Modeler"
      },
      {
        "command": "bpmn-modeler.newBpmn",
        "title": "New BPMN Diagram",
        "category": "BPMN Modeler",
        "icon": "$(add)"
      },
      {
        "command": "bpmn-modeler.newForm",
        "title": "New Camunda Form",
        "category": "BPMN Modeler",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "bpmn-modeler.newBpmn",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@1"
        },
        {
          "command": "bpmn-modeler.newForm",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@2"
        },
        {
          "command": "bpmn-modeler.openWithModeler",
          "when": "resourceExtname == .bpmn",
          "group": "navigation"
        },
        {
          "command": "bpmn-modeler.openFormEditor",
          "when": "resourceExtname == .form",
          "group": "navigation"
        },
        {
          "command": "bpmn-modeler.deploy",
          "when": "resourceExtname == .bpmn || resourceExtname == .form",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "bpmn-modeler.openWithModeler",
          "when": "resourceExtname == .bpmn",
          "group": "navigation"
        },
        {
          "command": "bpmn-modeler.openFormEditor",
          "when": "resourceExtname == .form",
          "group": "navigation"
        },
        {
          "command": "bpmn-modeler.deploy",
          "when": "resourceExtname == .bpmn || resourceExtname == .form",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "bpmn-modeler.deploy",
          "when": "resourceExtname == .bpmn || resourceExtname == .form",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "BPMN Modeler",
      "properties": {
        "bpmnModeler.camunda.endpoints": {
          "type": "array",
          "default": [
            {
              "name": "Local Camunda 7",
              "endpointUrl": "http://localhost:8080",
              "restPath": "/engine-rest",
              "basicAuthUser": "",
              "basicAuthPassword": ""
            }
          ],
          "description": "Camunda deployment targets. The user picks one when deploying.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "endpointUrl"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "endpointUrl": {
                "type": "string",
                "description": "Base URL, e.g. http://localhost:8080"
              },
              "restPath": {
                "type": "string",
                "default": "/engine-rest"
              },
              "basicAuthUser": {
                "type": "string",
                "default": ""
              },
              "basicAuthPassword": {
                "type": "string",
                "default": ""
              }
            }
          }
        },
        "bpmnModeler.camunda.endpointUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "(Legacy) Single Camunda REST API base URL. Use camunda.endpoints instead.",
          "deprecationMessage": "Use bpmnModeler.camunda.endpoints for multiple deployment targets."
        },
        "bpmnModeler.camunda.restPath": {
          "type": "string",
          "default": "/engine-rest",
          "description": "Camunda REST API path"
        },
        "bpmnModeler.camunda.basicAuthUser": {
          "type": "string",
          "default": "",
          "description": "Basic auth username (optional)"
        },
        "bpmnModeler.camunda.basicAuthPassword": {
          "type": "string",
          "default": "",
          "description": "Basic auth password (optional)"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "bpmn-modeler.bpmnEditor",
        "displayName": "BPMN Modeler",
        "selector": [
          {
            "filenamePattern": "*.bpmn"
          },
          {
            "filenamePattern": "**/*.bpmn"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "bpmn-modeler.formEditor",
        "displayName": "Form Editor",
        "selector": [
          {
            "filenamePattern": "*.form"
          },
          {
            "filenamePattern": "**/*.form"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.5.0",
    "mini-css-extract-plugin": "^2.10.2",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "@bpmn-io/form-js": "^1.21.3",
    "@bpmn-io/form-js-editor": "^1.21.3",
    "@bpmn-io/properties-panel": "^3.46.0",
    "bpmn-js": "^18.19.0",
    "bpmn-js-color-picker": "^0.7.2",
    "bpmn-js-create-append-anything": "^1.3.0",
    "bpmn-js-properties-panel": "^5.59.0",
    "camunda-bpmn-js-behaviors": "^1.16.1",
    "camunda-bpmn-moddle": "^7.0.1"
  }
}
